# 複製此檔為 .env 並填入實際值（.env 勿提交至版控）
# 正式環境請務必設定管理員帳號與密碼，否則無法登入後台

# 管理員帳號（後台登入時輸入的帳號；必填）
ADMIN_USERNAME=daynight1003@

# 管理員密碼（後台登入時輸入的密碼；必填）
ADMIN_PASSWORD=Alice1003@

# 選填：API Key（可替代帳號+密碼用於程式或整合）
ADMIN_API_KEY=

# 選填：服務 port，預設 3000（正式）或 5173（開發）
# PORT=3000

# 正式環境請設為 production
NODE_ENV=production
